# =============================================================================
#  config.env.example
#
#  Copy this file to config.env and fill in YOUR values.
#  config.env is gitignored and should never be committed.
#
#  Usage:
#    cp config.env.example config.env
#    nano config.env          # fill in your IPs and paths
# =============================================================================

# ---------------------------------------------------------------------------
# NODE IPs  (private/internal IPs — used by nodes to talk to each other)
# Add or remove entries to match your number of nodes.
# Order matters: index 0 = Node 0, index 1 = Node 1, etc.
# ---------------------------------------------------------------------------
NODE_IPS=(
    "10.0.0.1"    # Node 0  -- also the centralized FL server
    "10.0.0.2"    # Node 1
    "10.0.0.3"    # Node 2
    "10.0.0.4"    # Node 3
    "10.0.0.5"    # Node 4
    "10.0.0.6"    # Node 5
    "10.0.0.7"    # Node 6
    "10.0.0.8"    # Node 7
)

# ---------------------------------------------------------------------------
# PUBLIC IPs  (for SSH from your laptop — may change after instance restart)
# Must match the same order as NODE_IPS above.
# ---------------------------------------------------------------------------
PUBLIC_IPS=(
    "1.2.3.4"     # Node 0 public
    "1.2.3.5"     # Node 1 public
    "1.2.3.6"     # Node 2 public
    "1.2.3.7"     # Node 3 public
    "1.2.3.8"     # Node 4 public
    "1.2.3.9"     # Node 5 public
    "1.2.3.10"    # Node 6 public
    "1.2.3.11"    # Node 7 public
)

# ---------------------------------------------------------------------------
# SSH settings
# ---------------------------------------------------------------------------
SSH_KEY_PATH="~/.ssh/your-key.pem"    # path to your private key
SSH_USER="ubuntu"                      # default for AWS Ubuntu AMIs

# ---------------------------------------------------------------------------
# Remote node configuration
# ---------------------------------------------------------------------------
REMOTE_DIR="~/fl_project"             # directory on each remote node
NUM_NODES=${#NODE_IPS[@]}             # auto-computed from NODE_IPS length
